{%- liquid
  assign bg_color = section.settings.bg_color
  assign logo_image = section.settings.logo_image
  assign copyright_text = section.settings.copyright_text
  assign pt_desktop = section.settings.padding_top_desktop
  assign pb_desktop = section.settings.padding_bottom_desktop
  assign pt_mobile = section.settings.padding_top_mobile
  assign pb_mobile = section.settings.padding_bottom_mobile
  assign hide_paths = section.settings.hide_on_pages | split: ','
  assign should_hide = false
  for raw_path in hide_paths
    assign trimmed_path = raw_path | strip
    if trimmed_path != blank and request.path == trimmed_path
      assign should_hide = true
    endif
  endfor
-%}

<style>
  #shopify-section-{{ section.id }} {
    width: 100%;
  }

  {%- if should_hide -%}
  #shopify-section-{{ section.id }} { display: none !important; }
  {%- endif -%}

  .custom-footer-{{ section.id }} {
    background-color: {{ bg_color }};
    width: 100%;
  }

  .custom-footer-inner-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: {{ pt_desktop }}px;
    padding-bottom: {{ pb_desktop }}px;
    padding-left: 40px;
    padding-right: 40px;
    box-sizing: border-box;
  }

  /* Logo */
  .custom-footer-logo-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .custom-footer-logo-{{ section.id }} img,
  .custom-footer-logo-{{ section.id }} svg {
    max-height: 70px;
    width: auto;
    display: block;
  }

  /* Copyright */
  .custom-footer-copyright-{{ section.id }} {
    font-family: 'Archivo Narrow', sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 11px;
    line-height: 18.15px;
    letter-spacing: 0.22px;
    text-align: center;
    text-transform: uppercase;
    color: #EFE5F1;
    margin: 0;
  }

  /* Tablet */
  @media screen and (max-width: 1100px) {
    .custom-footer-inner-{{ section.id }} {
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .custom-footer-inner-{{ section.id }} {
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding-top: {{ pt_mobile }}px;
      padding-bottom: {{ pb_mobile }}px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .custom-footer-logo-{{ section.id }} img,
    .custom-footer-logo-{{ section.id }} svg {
      max-height: unset;
      max-width: 63px;
    }

    .custom-footer-copyright-{{ section.id }} {
      text-align: left;
    }
  }
</style>

