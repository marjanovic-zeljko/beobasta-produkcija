      tabindex="0"
      aria-label="Scroll to top"
      onclick="document.documentElement.scrollTo({ top: 0, behavior: 'smooth' });"
      onkeydown="if(event.key==='Enter'||event.key===' '){document.documentElement.scrollTo({ top: 0, behavior: 'smooth' });}"
    >
      {%- if logo_image != blank -%}
        {{
          logo_image
          | image_url: width: 340
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            alt: shop.name
