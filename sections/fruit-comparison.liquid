    {
      "type": "range",
      "id": "card_padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Unutrašnji razmak kartice",
      "default": 24
    },
    {
      "type": "header",
      "content": "Razmaci"
