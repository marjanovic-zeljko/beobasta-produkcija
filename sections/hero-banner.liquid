{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}
{%- assign overlay_r = section.settings.overlay_color.red -%}
{%- assign overlay_g = section.settings.overlay_color.green -%}
{%- assign overlay_b = section.settings.overlay_color.blue -%}

<style>
  #shopify-section-{{ section.id }} {
    --hero-desktop-height: {{ section.settings.desktop_height }}px;
    --hero-mobile-height: {{ section.settings.mobile_height }}px;
    --hero-overlay-bg: rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_opacity }});
    --hero-content-max-width: {{ section.settings.content_max_width }}px;
    --hero-heading-color: {{ section.settings.heading_color }};
    --hero-subheading-color: {{ section.settings.subheading_color }};
    --hero-text-color: {{ section.settings.text_color }};
    --hero-btn-bg: {{ section.settings.button_bg_color }};
    --hero-btn-text: {{ section.settings.button_text_color }};
    --hero-btn-hover-bg: {{ section.settings.button_hover_bg_color }};
    --hero-btn-hover-text: {{ section.settings.button_hover_text_color }};
    --hero-desktop-img-position: {{ section.settings.desktop_image_position }};
    --hero-mobile-img-position: {{ section.settings.mobile_image_position }};
    --hero-desktop-valign: {{ section.settings.desktop_content_valign }};
    --hero-mobile-valign: {{ section.settings.mobile_content_valign }};
    --hero-desktop-text-align: {{ section.settings.desktop_content_align }};
    --hero-mobile-text-align: {{ section.settings.mobile_content_align }};
    --hero-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --hero-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    --hero-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --hero-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    --hero-desktop-text-gap: {{ section.settings.desktop_text_gap }}px;
    --hero-mobile-text-gap: {{ section.settings.mobile_text_gap }}px;
  }

  #shopify-section-{{ section.id }} .hero-banner {
    position: relative;
    overflow: hidden;
    min-height: var(--hero-desktop-height);
  }

  #shopify-section-{{ section.id }} .hero-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .hero-banner__media img,
  #shopify-section-{{ section.id }} .hero-banner__media .placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-desktop-img-position);
  }

  #shopify-section-{{ section.id }} .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--hero-overlay-bg);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .hero-banner__content-outer {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    width: 100%;
    min-height: var(--hero-desktop-height);
    max-width: calc(var(--container-lg-max-width) + var(--container-gutter) * 2);
    margin-inline: auto;
    padding-inline: var(--container-gutter);
    padding-top: var(--hero-desktop-padding-top);
    padding-bottom: var(--hero-desktop-padding-bottom);
    display: flex;
    align-items: var(--hero-desktop-valign);
    text-align: var(--hero-desktop-text-align);
  }

  #shopify-section-{{ section.id }} .hero-banner__content {
    max-width: var(--hero-content-max-width);
    display: flex;
    flex-direction: column;
    gap: var(--hero-desktop-text-gap);
  }

  #shopify-section-{{ section.id }} .hero-banner__heading {
    margin: 0;
    font-family: var(--heading-font-family);
    font-weight: 600;
    font-size: var(--text-h2);
    line-height: 1;
    text-transform: uppercase;
    color: var(--hero-heading-color);
  }

  #shopify-section-{{ section.id }} .hero-banner__subheading {
    margin: 0;
    font-family: var(--heading-font-family);
    font-weight: 600;
    font-size: var(--text-h5);
    line-height: 1.3;
    letter-spacing: 0;
    color: var(--hero-subheading-color);
  }

  #shopify-section-{{ section.id }} .hero-banner__text {
    font-family: var(--text-font-family);
    font-weight: 400;
    font-size: var(--text-base);
    line-height: 1.3;
    letter-spacing: 0;
    color: var(--hero-text-color);
  }

  #shopify-section-{{ section.id }} .hero-banner__text p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hero-banner__text p + p {
    margin-top: 0.375rem;
  }

  #shopify-section-{{ section.id }} .hero-banner__btn-wrapper {
    display: flex;
  }

  #shopify-section-{{ section.id }} .hero-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2.25rem;
    background-color: var(--hero-btn-bg);
    color: var(--hero-btn-text);
    font-family: var(--text-font-family);
    font-weight: 600;
    font-size: var(--text-base);
    line-height: 1.1;
    letter-spacing: 0.16em;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .hero-banner__btn:hover {
    background-color: var(--hero-btn-hover-bg);
    color: var(--hero-btn-hover-text);
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .hero-banner {
      min-height: var(--hero-mobile-height);
    }

    #shopify-section-{{ section.id }} .hero-banner__media img,
    #shopify-section-{{ section.id }} .hero-banner__media .placeholder {
      object-position: var(--hero-mobile-img-position);
    }

    #shopify-section-{{ section.id }} .hero-banner__content-outer {
      min-height: var(--hero-mobile-height);
      padding-top: var(--hero-mobile-padding-top);
      padding-bottom: var(--hero-mobile-padding-bottom);
      align-items: var(--hero-mobile-valign);
      text-align: var(--hero-mobile-text-align);
    }

    #shopify-section-{{ section.id }} .hero-banner__content {
      gap: var(--hero-mobile-text-gap);
      width: 100%;
    }

    #shopify-section-{{ section.id }} .hero-banner__heading {
      font-size: var(--text-h3);
    }

    #shopify-section-{{ section.id }} .hero-banner__btn-wrapper {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .hero-banner__btn {
      width: 100%;
      white-space: normal;
    }
  }
</style>

<div class="hero-banner">
  <div class="hero-banner__media">
    {%- if section.settings.desktop_image != blank -%}
      <picture>
        {%- if section.settings.mobile_image != blank -%}
          <source
            media="(max-width: 699px)"
            srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w"
            width="{{ section.settings.mobile_image.width }}"
            height="{{ section.settings.mobile_image.height }}"
          >
        {%- endif -%}

        {{- section.settings.desktop_image | image_url: width: section.settings.desktop_image.width | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '400,600,800,1000,1200,1600,1920,2400,2800,3200' -}}
      </picture>
    {%- else -%}
      {{- 'lifestyle-2' | placeholder_svg_tag: 'placeholder' -}}
    {%- endif -%}

    <div class="hero-banner__overlay"></div>
  </div>

  <div class="hero-banner__content-outer">
    <div class="hero-banner__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            {%- if block.settings.text != blank -%}
              <p class="hero-banner__subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}

          {%- when 'heading' -%}
            {%- if block.settings.text != blank -%}
              <h1 class="hero-banner__heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h1>
            {%- endif -%}

          {%- when 'text' -%}
            {%- if block.settings.content != blank -%}
              <div class="hero-banner__text" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
            {%- endif -%}

          {%- when 'button' -%}
            {%- if block.settings.label != blank -%}
              {%- liquid
                assign btn_link_type = block.settings.button_link_type | default: 'url'
                assign scroll_raw = block.settings.scroll_target | strip
                assign btn_href = '#'
                assign btn_smooth = false
                if btn_link_type == 'section' and scroll_raw != blank
                  if scroll_raw contains 'shopify-section'
                    assign scroll_anchor = scroll_raw
                  elsif scroll_raw contains 'template--'
                    assign scroll_anchor = 'shopify-section-' | append: scroll_raw
                  else
                    assign scroll_anchor = scroll_raw | handleize
                  endif
                  assign btn_href = '#' | append: scroll_anchor
                  assign btn_smooth = true
                elsif btn_link_type == 'section' and scroll_raw == blank and block.settings.link != blank
                  assign btn_href = block.settings.link
                elsif block.settings.link != blank
                  assign btn_href = block.settings.link
                endif
              -%}
              <div class="hero-banner__btn-wrapper" {{ block.shopify_attributes }}>
                <a
                  href="{{ btn_href }}"
                  class="hero-banner__btn"
                  {% if btn_smooth %}
                    data-smooth-scroll
                  {% endif %}
                >
                  {{- block.settings.label -}}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if section.blocks.size > 0 -%}
  <script>
    (function () {
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (!sectionEl) return;
      sectionEl.querySelectorAll('[data-smooth-scroll]').forEach(function (link) {
        link.addEventListener('click', function (e) {
          var href = link.getAttribute('href');
          if (!href || href === '#') return;
          var targetId = href.replace(/^#/, '');
          var target = document.getElementById(targetId);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    })();
  </script>
{%- endif -%}

