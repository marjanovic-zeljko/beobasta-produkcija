    "faq_two_column_ppfhXw": {
      "type": "faq-two-column",
      "blocks": {
        "faq_item_66jFDN": {
          "type": "faq_item",
          "settings": {
            "question": "Kada mi stiže voće koje poručim?",
            "answer": "<p>Kada berba krene, voće stiže na tvoju adresu za najviše 24 sata od trenutka branja. Zrenje i berba zavise od vremenskih prilika i temperature vazduha.Ukoliko pada kiša, branje nije moguće i tada s tobom dogovaramo tačan datum i vreme dostave.</p>",
            "open_by_default": true
          }
        },
        "faq_item_rzV96d": {
          "type": "faq_item",
          "settings": {
            "question": "Koliko voće može da traje i kako se pravilno čuva?",
            "answer": "<p>Najbolje je konzumirati odmah ili pojesti u najkraćem roku, jer tada ima pun ukus. Ako se ipak odlučiš za čuvanje, možeš ga zamrznuti.</p>",
            "open_by_default": false
          }
        },
        "faq_item_8DCE3e": {
          "type": "faq_item",
          "settings": {
            "question": "Gde mogu da proverim da je voće zaista bez ostataka pesticida?",
            "answer": "<p>Kada se završi laboratorijski ispitivanje, dokumenti će javno biti dostupni na ovom mestu.</p>",
            "open_by_default": false
          }
        },
        "faq_item_3L9X8R": {
          "type": "faq_item",
          "settings": {
            "question": "Kako da poručim i platim?",
            "answer": "<p>Poručivanje se vrši dodavanjem proizvoda u korpu. Dodavanje možeš ponavljati sve dok ne poručiš sve što želiš. Sadržaj korpe možeš proveriti na vrhu stranice. Ako ti je potrebna pomoć, možeš nas kontaktirati putem društvenih mreža ili e-maila. Plaćanje se vrši pouzećem nakon isporuke.</p>",
            "open_by_default": false
          }
        },
        "faq_item_VTQGMk": {
          "type": "faq_item",
          "settings": {
            "question": "Gde se sve vrši dostava?",
            "answer": "<p>Dostava za Beograd (za opštine: Čukarica, Novi Beograd, Rakovica, Palilula, Savski venac, Stari grad, Surčin, Voždovac, Vračar, Zemun i Zvezdara), Novi Sad (uključujući Sremsku Kamenicu, Petrovaradin, Futog), Stare i Nove Banovce, Staru i Novu Pazovu, Inđiju, Pančevo i Mladenovac.<br/><br/></p>",
            "open_by_default": false
          }
        },
        "faq_item_g84EYQ": {
          "type": "faq_item",
          "settings": {
            "question": "Koja je cena dostave?",
            "answer": "<p>Cene dostave i više informacija o transportu možeš pogledati ovde.</p>",
            "open_by_default": false
          }
        },
        "faq_item_FAEdRj": {
          "type": "faq_item",
          "settings": {
            "question": "Da li mogu ostvariti pravo na reklamaciju ukoliko dobijem voće koje ne dogovara opisu?",
            "answer": "<p>Ukoliko ustanoviš da proizvod ne zadovoljava kriterijume kvaliteta (ima vidljive nedostatke i promene), možeš nam uputiti Zahtev za reklamaciju putem elektronske pošte na kontakt@beobasta.rs. <br/><br/>Utvrdićemo da li je reklamacija osnovana i u zakonskom roku doneti odluku kojom se odobrava ili odbija. Ukoliko ustanovimo da je reklamacija opravdana, zamenićemo proizvod za isti bez nedostataka. <br/><br/>Ukoliko ne možemo da zamenimo proizvod jer ga više nema na lageru, možeš preuzeti drugi proizvod u istoj vrednosti ili skuplji proizvod uz doplatu ili možeš tražiti povraćaj novca.</p>",
            "open_by_default": false
          }
        }
