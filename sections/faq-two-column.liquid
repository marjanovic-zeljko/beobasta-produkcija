<style>
  #shopify-section-{{ section.id }} {
    --faq2-bg: {{ section.settings.background_color }};
    --faq2-max-width: {{ section.settings.content_max_width }}px;
    --faq2-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --faq2-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --faq2-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --faq2-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }

  #shopify-section-{{ section.id }} .faq2col {
    background-color: var(--faq2-bg);
    padding-top: var(--faq2-pt-desktop);
    padding-bottom: var(--faq2-pb-desktop);
  }

  #shopify-section-{{ section.id }} .faq2col__inner {
    max-width: calc(var(--faq2-max-width) + var(--container-gutter, 80px) * 2);
    margin-inline: auto;
    padding-inline: var(--container-gutter, 80px);
  }

  #shopify-section-{{ section.id }} .faq2col__layout {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 80px;
    align-items: start;
  }

  /* Left column */
  #shopify-section-{{ section.id }} .faq2col__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .faq2col__heading {
    margin: 0;
    font-family: var(--heading-font-family);
    font-weight: 600;
    font-size: var(--text-h3);
    line-height: 110%;
    letter-spacing: 0;
    color: #030303;
  }

  #shopify-section-{{ section.id }} .faq2col__description {
    margin: 0;
    font-family: var(--text-font-family);
    font-weight: 400;
    font-size: var(--text-base);
    line-height: 130%;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__description p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__cta {
    display: inline-block;
    font-family: var(--text-font-family);
    font-weight: 600;
    font-size: var(--text-base);
    line-height: 110%;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid currentColor;
    padding-bottom: 3px;
    transition: border-bottom-color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .faq2col__cta:hover {
    border-bottom-color: transparent;
  }

  /* Right column – accordion */
  #shopify-section-{{ section.id }} .faq2col__accordion {
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  #shopify-section-{{ section.id }} .faq2col__item + .faq2col__item {
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  #shopify-section-{{ section.id }} .faq2col__item-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 20px 0;
    gap: 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .faq2col__question {
    flex: 1;
    font-family: var(--heading-font-family);
    font-weight: 600;
    font-size: var(--text-h6);
    line-height: 130%;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .faq2col__icon--minus {
    display: none;
  }

  #shopify-section-{{ section.id }} .faq2col__item[data-open] .faq2col__icon--plus {
    display: none;
  }

  #shopify-section-{{ section.id }} .faq2col__item[data-open] .faq2col__icon--minus {
    display: flex;
  }

  /* Smooth height animation using CSS grid trick */
  #shopify-section-{{ section.id }} .faq2col__item-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  #shopify-section-{{ section.id }} .faq2col__item[data-open] .faq2col__item-body {
    grid-template-rows: 1fr;
  }

  #shopify-section-{{ section.id }} .faq2col__item-body-inner {
    overflow: hidden;
    min-height: 0;
    padding-bottom: 0;
    transition: padding-bottom 0.35s ease;
  }

  #shopify-section-{{ section.id }} .faq2col__item[data-open] .faq2col__item-body-inner {
    padding-bottom: 20px;
  }

  #shopify-section-{{ section.id }} .faq2col__answer {
    font-family: var(--text-font-family);
    font-weight: 400;
    font-size: var(--text-base);
    line-height: 130%;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__answer p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .faq2col__answer p + p {
    margin-top: 0.75em;
  }

  /* Mobile */
  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .faq2col {
      padding-top: var(--faq2-pt-mobile);
      padding-bottom: var(--faq2-pb-mobile);
    }

    #shopify-section-{{ section.id }} .faq2col__inner {
      padding-inline: 20px;
    }

    #shopify-section-{{ section.id }} .faq2col__layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .faq2col__left {
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .faq2col__heading {
      font-size: var(--text-h4);
      text-align: center;
    }

    #shopify-section-{{ section.id }} .faq2col__description {
      text-align: center;
    }

    #shopify-section-{{ section.id }} .faq2col__item-trigger {
      padding: 16px 0;
    }
  }
</style>

{%- assign first_open_assigned = false -%}

<div class="faq2col">
  <div class="faq2col__inner">
    <div class="faq2col__layout">

      <div class="faq2col__left">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq2col__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="faq2col__description">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a class="faq2col__cta" href="{{ section.settings.cta_link | default: '#' }}">
            {{- section.settings.cta_label -}}
          </a>
        {%- endif -%}
      </div>

      <div class="faq2col__right">
        {%- if section.blocks.size > 0 -%}
          <div class="faq2col__accordion" id="faq2col-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- assign is_open = false -%}
              {%- if block.settings.open_by_default and first_open_assigned == false -%}
                {%- assign is_open = true -%}
                {%- assign first_open_assigned = true -%}
              {%- endif -%}

              <div class="faq2col__item" {% if is_open %}data-open{% endif %} {{ block.shopify_attributes }}>
                <button
                  class="faq2col__item-trigger"
                  aria-expanded="{{ is_open }}"
                  aria-controls="faq2col-answer-{{ block.id }}"
                >
                  <span class="faq2col__question">{{ block.settings.question }}</span>
                  <span class="faq2col__icon-wrap" aria-hidden="true">
                    <span class="faq2col__icon faq2col__icon--plus">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 6.66667H0V5H5V0H6.66667V5H11.6667V6.66667H6.66667V11.6667H5V6.66667Z" fill="#9E9E9E"/>
                      </svg>
                    </span>
                    <span class="faq2col__icon faq2col__icon--minus">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 5H11.6667V6.66667H0V5Z" fill="#9E9E9E"/>
                      </svg>
                    </span>
                  </span>
                </button>
                <div class="faq2col__item-body" id="faq2col-answer-{{ block.id }}" role="region">
                  <div class="faq2col__item-body-inner">
                    <div class="faq2col__answer">{{ block.settings.answer }}</div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<script>
  (function () {
    var accordion = document.getElementById('faq2col-{{ section.id }}');
    if (!accordion || accordion.dataset.initialized) return;
    accordion.dataset.initialized = 'true';

    accordion.querySelectorAll('.faq2col__item-trigger').forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var item = this.closest('.faq2col__item');
        var isOpen = item.hasAttribute('data-open');

        accordion.querySelectorAll('.faq2col__item').forEach(function (el) {
          el.removeAttribute('data-open');
          el.querySelector('.faq2col__item-trigger').setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
          item.setAttribute('data-open', '');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ dvostubac",
  "class": "shopify-section--faq-two-column",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Sadržaj"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Naslov",
      "default": "Često postavljana pitanja"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Opis",
      "default": "<p>Ovde možete pronaći odgovore na najčešće postavljana pitanja o našim proizvodima i usluzi.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Tekst dugmeta"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link dugmeta"
    },
    {
      "type": "header",
      "content": "Dizajn"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Pozadina sekcije",
      "default": "#F5F0E8"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maksimalna širina sadržaja",
      "default": 1280
    },
    {
      "type": "header",
      "content": "Razmaci"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Gornji razmak – desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Donji razmak – desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Gornji razmak – mobilni",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Donji razmak – mobilni",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ stavka",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "question",
          "label": "Pitanje",
          "default": "Kako se vrši dostava?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Odgovor",
          "default": "<p>Naša dostava je brza i pouzdana. Voće se bere isti dan i isporučuje u roku od 24 sata.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Otvorena po defaultu",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ dvostubac",
      "category": "Content",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Kako se vrši dostava?",
            "answer": "<p>Naša dostava je brza i pouzdana. Voće se bere isti dan i isporučuje u roku od 24 sata.</p>",
            "open_by_default": true
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Da li radite vikendom?",
            "answer": "<p>Da, dostavljamo i subotom i nedeljom. Porudžbine primamo svaki dan.</p>",
            "open_by_default": false
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Kako mogu da platim?",
            "answer": "<p>Prihvatamo plaćanje gotovinom pri dostavi, kao i kartičnim plaćanjem online.</p>",
            "open_by_default": false
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Mogu li da promenim ili otkažem porudžbinu?",
            "answer": "<p>Porudžbinu možete promeniti ili otkazati najkasnije sat vremena pre isporuke kontaktiranjem naše podrške.</p>",
            "open_by_default": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
