      "options": [
        { "value": "left", "label": "Levo" },
        { "value": "center", "label": "Centar" },
        { "value": "right", "label": "Desno" }
      ],
      "default": "center",
      "info": "Tekst će biti poravnat unutar centriranog okvira"
