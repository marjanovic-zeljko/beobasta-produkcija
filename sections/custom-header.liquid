{%- liquid
  assign bg_color = section.settings.bg_color
  assign logo_image = section.settings.logo_image
  assign cta_text = section.settings.cta_text
  assign cta_target = section.settings.cta_target
  assign cta_anchor = ''
  assign cta_trim = cta_target | strip
  if cta_trim != blank
    if cta_trim contains 'shopify-section'
      assign cta_anchor = cta_trim
    elsif cta_trim contains 'template--'
      assign cta_anchor = 'shopify-section-' | append: cta_trim
    else
      assign cta_anchor = cta_trim | handleize
    endif
  endif
  assign sticky = section.settings.enable_sticky
  assign pt_desktop = section.settings.padding_top_desktop
  assign pb_desktop = section.settings.padding_bottom_desktop
  assign pt_mobile = section.settings.padding_top_mobile
  assign pb_mobile = section.settings.padding_bottom_mobile
  assign hide_paths = section.settings.hide_on_pages | split: ','
  assign should_hide = false
  for raw_path in hide_paths
    assign trimmed_path = raw_path | strip
    if trimmed_path != blank and request.path == trimmed_path
      assign should_hide = true
    endif
  endfor
-%}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 100;
    width: 100%;
  }

  {%- if should_hide -%}
  #shopify-section-{{ section.id }} { display: none !important; }
  {%- endif -%}

  .custom-header-{{ section.id }} {
    background-color: {{ bg_color }};
    width: 100%;
    {% if sticky %}
    position: sticky;
    top: 0;
    z-index: 100;
    {% endif %}
  }

  .custom-header-inner-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: {{ pt_desktop }}px;
    padding-bottom: {{ pb_desktop }}px;
    padding-left: 40px;
    padding-right: 40px;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Logo */
  .custom-header-logo-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    cursor: pointer;
  }

  .custom-header-logo-{{ section.id }} img,
  .custom-header-logo-{{ section.id }} svg {
    max-height: 70px;
    width: auto;
    display: block;
  }

  /* Nav */
  .custom-header-nav-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .custom-header-nav-{{ section.id }} li a {
    font-family: var(--font-secondary, sans-serif);
    font-weight: 400;
    font-size: var(--text-main, 14px);
    line-height: 130%;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #EFE5F1;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .custom-header-nav-{{ section.id }} li a:hover {
    opacity: 0.7;
  }

  /* CTA Button */
  .custom-header-cta-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .custom-header-cta-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 349px;
    height: 44px;
    padding: var(--space-2, 8px) var(--space-5, 20px);
    border-radius: 30px;
    border: 1px solid #DDB957;
    background: #DDB957;
    color: #000;
    font-family: var(--font-primary, sans-serif);
    font-weight: 600;
    font-size: var(--text-main, 14px);
    line-height: 110%;
    letter-spacing: 0.16em;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .custom-header-cta-btn-{{ section.id }}:hover {
    background: transparent;
    color: #DDB957;
  }

  /* Hamburger */
  .custom-header-hamburger-{{ section.id }} {
    display: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Mobile menu */
  .custom-header-mobile-menu-{{ section.id }} {
    display: none;
    flex-direction: column;
    background-color: {{ bg_color }};
    padding: 24px 24px 32px;
    gap: 24px;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease, padding 0.35s ease;
  }

  .custom-header-mobile-menu-{{ section.id }}.is-open {
    display: flex;
    max-height: 600px;
    padding: 24px 24px 32px;
  }

  .custom-header-mobile-nav-{{ section.id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .custom-header-mobile-nav-{{ section.id }} li a {
    font-family: var(--font-secondary, sans-serif);
    font-weight: 400;
    font-size: var(--text-main, 14px);
    line-height: 130%;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #EFE5F1;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    display: block;
  }

  .custom-header-mobile-nav-{{ section.id }} li a:hover {
    opacity: 0.7;
  }

  .custom-header-mobile-cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 44px;
    padding: var(--space-2, 8px) var(--space-5, 20px);
    border-radius: 30px;
    border: 1px solid #DDB957;
    background: #DDB957;
    color: #000;
    font-family: var(--font-primary, sans-serif);
    font-weight: 600;
    font-size: var(--text-main, 14px);
    line-height: 110%;
    letter-spacing: 0.16em;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    box-sizing: border-box;
  }

  .custom-header-mobile-cta-{{ section.id }}:hover {
    background: transparent;
    color: #DDB957;
  }

  /* Tablet */
  @media screen and (max-width: 1100px) {
    .custom-header-inner-{{ section.id }} {
      padding-left: 24px;
      padding-right: 24px;
    }

    .custom-header-nav-{{ section.id }} {
      gap: 24px;
    }

    .custom-header-cta-btn-{{ section.id }} {
      width: auto;
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .custom-header-inner-{{ section.id }} {
      padding-top: {{ pt_mobile }}px;
      padding-bottom: {{ pb_mobile }}px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .custom-header-nav-{{ section.id }},
    .custom-header-cta-{{ section.id }} {
      display: none;
    }

    .custom-header-hamburger-{{ section.id }} {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .custom-header-logo-{{ section.id }} img,
    .custom-header-logo-{{ section.id }} svg {
      max-height: unset;
      max-width: 63px;
    }
  }
</style>

<header
  class="custom-header-{{ section.id }}"
  role="banner"
  aria-label="{{ 'sections.header.title' | t | default: 'Site header' }}"
>
